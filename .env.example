# Copy to .env and fill in (do not commit .env).
# Or: export these variables in your shell before starting the bridge.

# Required — Crosswork / SSO base URL (no trailing slash), e.g. https://crosswork.example.com:443
CWM_CROSSWORK_BASE_URL=

# Required — CAS credentials used by the bridge to obtain a JWT
CWM_CAS_USERNAME=
CWM_CAS_PASSWORD=

# Optional — override API paths if your deployment differs
# CWM_MCP_PATH=/crosswork/cwm/v2/mcp
# CWM_CAS_PATH=/crosswork/sso
# CWM_INVENTORY_QUERY_PATH=/crosswork/cwms/inventory/v1/devices/query

# Optional — set to true only if Crosswork presents a publicly trusted TLS chain
CWM_SSL_VERIFY=false

# Optional — if CAS returns a TGT Location with an internal port, set the public port (digits only)
# CWM_SSO_EXTERNAL_PORT=30603

# Optional — helper scripts (post_workflow_from_file.py, run_job_from_input.py)
# CWM_BRIDGE_URL=http://127.0.0.1:9093/crosswork/cwm/v2/mcp
